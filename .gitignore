# App data (created at runtime — never commit field day data)
app_settings.json
fielddays/
exports/

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets (extra safety)
github_token.txt
*.token

# Logs
*.log
