# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/

# Virtual environment
venv/
.venv/
env/

# PyInstaller build output
build/
dist/
*.spec.bak

# Assets (generated by build_assets.py — do not commit binary icon)
assets/icon.ico
